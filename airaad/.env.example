# =============================================================================
# AirAd Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before running the application.
# NEVER commit .env to version control.
# Zero literal placeholder values — all values below are generation instructions.
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Django environment: development | production | test
DJANGO_SETTINGS_MODULE=config.settings.development

# Comma-separated list of allowed hosts, e.g.: localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Set to False in production
DEBUG=True

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------

# AES-256-GCM key — must be exactly 32 bytes, base64-encoded.
# Generate with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Database (PostgreSQL + PostGIS)
# -----------------------------------------------------------------------------

# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Example: postgres://airaad:strongpassword@localhost:5432/airaad_db
DATABASE_URL=

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# Format: redis://[:PASSWORD@]HOST:PORT/DB_NUMBER
# Example: redis://localhost:6379/0
REDIS_URL=

# -----------------------------------------------------------------------------
# AWS S3 (File Storage)
# -----------------------------------------------------------------------------

# Generate in AWS IAM Console → Users → Security credentials → Create access key
AWS_ACCESS_KEY_ID=

# The secret key paired with the access key above
AWS_SECRET_ACCESS_KEY=

# S3 bucket name — must already exist and have appropriate IAM policy
AWS_STORAGE_BUCKET_NAME=

# AWS region where the bucket is located, e.g.: us-east-1, ap-south-1
AWS_S3_REGION_NAME=

# Presigned URL expiry in seconds (default: 3600 = 1 hour)
AWS_S3_PRESIGNED_URL_EXPIRY=3600

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------

# Celery broker URL — typically same as REDIS_URL
# Format: redis://[:PASSWORD@]HOST:PORT/DB_NUMBER
CELERY_BROKER_URL=

# Celery result backend URL
CELERY_RESULT_BACKEND=

# -----------------------------------------------------------------------------
# Email (optional — for admin notifications)
# -----------------------------------------------------------------------------

# SMTP host, e.g.: smtp.sendgrid.net
EMAIL_HOST=

# SMTP port, e.g.: 587
EMAIL_PORT=587

# SMTP username
EMAIL_HOST_USER=

# SMTP password or API key
EMAIL_HOST_PASSWORD=

# Default from address, e.g.: noreply@yourdomain.com
DEFAULT_FROM_EMAIL=

# -----------------------------------------------------------------------------
# Twilio (Phase B — OTP SMS)
# -----------------------------------------------------------------------------

# Twilio Account SID — found in Twilio Console Dashboard
TWILIO_ACCOUNT_SID=

# Twilio Auth Token — found in Twilio Console Dashboard
TWILIO_AUTH_TOKEN=

# Twilio phone number to send SMS from, e.g.: +12025551234
TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Frontend URL for CORS, e.g.: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Internal service port (used by gunicorn inside Docker)
PORT=8000
